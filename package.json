{
  "name": "codex-session-manager",
  "version": "1.0.0",
  "description": "Local web app for managing Codex CLI sessions safely.",
  "main": "src/server/index.ts",
  "scripts": {
    "app": "concurrently -k -n api,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1 --port 3767",
    "server": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "test": "vitest run",
    "audit:app": "npm run test && npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "better-sqlite3": "^12.10.0",
    "fastify": "^5.8.5",
    "lucide-react": "^1.16.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
